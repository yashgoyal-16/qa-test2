# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_API_KEY2: Custom Gemini API key requested by user.
GEMINI_API_KEY2="MY_GEMINI_API_KEY2"

# ZAI_API_KEY: Z.AI (Zhipu/GLM) API key. Used as the first fallback in the
# evaluation chain. Free tier supports GLM-4.7-Flash and GLM-4.5-Flash;
# requests >8K tokens are throttled to 1% concurrency on the free tier
# (typically 30-60s per request) but still complete.
ZAI_API_KEY="MY_ZAI_API_KEY"

# OPENROUTER_API_KEY: Optional OpenRouter API key for GPT-4o fallback.
# Note: max_tokens is set to 2048 to fit on small-credit accounts.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# VITE_DEEPGRAM_API_KEY: Required for Deepgram STT API calls.
VITE_DEEPGRAM_API_KEY="MY_DEEPGRAM_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
