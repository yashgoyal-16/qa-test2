# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_API_KEY2: Optional second Gemini key. Each Google API key has its
# own quota and concurrency budget — adding a second key effectively
# doubles capacity and significantly reduces 429/503 errors during peak
# Google-side load. Strongly recommended.
GEMINI_API_KEY2="MY_GEMINI_API_KEY2"

# OPENROUTER_API_KEY: Optional OpenRouter API key for GPT-4o as last-resort
# fallback. Note: max_tokens is set to 2048 to fit on small-credit accounts.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# VITE_DEEPGRAM_API_KEY: Required for Deepgram STT API calls.
VITE_DEEPGRAM_API_KEY="MY_DEEPGRAM_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
